model Order {
  id         String      @id @default(uuid())
  customerId String
  gearItemId String
  status     OrderStatus @default(PLACED)
  startDate  DateTime
  endDate    DateTime
  quantity   Int         @default(1)
  totalPrice Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  customer User @relation("Orders", fields: [customerId], references: [id], onDelete: Cascade)

  gearItem GearItem @relation(fields: [gearItemId], references: [id])

  payment Payment?

  @@map("orders")
}
