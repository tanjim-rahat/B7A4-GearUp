model GearItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  brand       String
  pricePerDay Float
  stock       Int      @default(1)
  isAvailable Boolean  @default(true)
  providerId  String
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  provider   User        @relation("ProviderGear", fields: [providerId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  reviews    Review[]

  @@map("gear_items")
}
